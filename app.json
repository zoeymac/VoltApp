{
  "expo": {
    "name": "VoltRide",
    "slug": "VoltApp2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFAF3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ca.voltride.app",
      "config": {
        "googleMapsApiKey": "AIzaSyAfzKEAH1z7S3jHQizI8KDOLl6vVwwpK6M"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDFAF3"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAfzKEAH1z7S3jHQizI8KDOLl6vVwwpK6M"
        }
      },
      "edgeToEdgeEnabled": true,
      "package": "ca.voltride.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
